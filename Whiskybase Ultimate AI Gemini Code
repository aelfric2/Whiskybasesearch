// ==UserScript==
// @name         Whiskybase Ultimate AI V30.2 (Gemini 2.0 Flash & Filtered)
// @version      30.2
// @description  Sichere Key-Speicherung, Cache-Buster & Gemini 2.0 Flash Modell
// @author       Gemini
// @match        *://*/*
// @grant        GM_xmlhttpRequest
// @grant        GM_getValue
// @grant        GM_setValue
// @connect      generativelanguage.googleapis.com
// @connect      gist.githubusercontent.com
// ==/UserScript==
 
(function() {
    'use strict';
    const DB_URL = 'https://gist.githubusercontent.com/aelfric2/5dd08669d7d4b4a9f3b25d1b98e91120/raw/whiskydb.json';
    let whiskySources = [];
 
    // Key sicher verwalten
    function getApiKey() {
        let key = GM_getValue('gemini_key', null);
        if (!key) {
            key = prompt("Whiskybase Ultimate AI (Gemini): Bitte gib deinen Google Gemini API-Key ein:");
            if (key) GM_setValue('gemini_key', key);
        }
        return key;
    }
 
    // Datenbank laden mit Cache-Buster
    GM_xmlhttpRequest({
        method: "GET",
        url: DB_URL + "?t=" + Date.now(),
        onload: (res) => { 
            try { 
                const data = JSON.parse(res.responseText); 
                let allTerms = [];
                Object.keys(data).forEach(key => {
                    if (Array.isArray(data[key])) allTerms = allTerms.concat(data[key]);
                });
                whiskySources = [...new Set(allTerms)];
                console.log("Whiskybase Gemini 2.0 AI: Begriffe geladen:", whiskySources.length);
            } catch(e) { console.error("JSON-Fehler:", e); } 
        }
    });
 
    const btnStyle = "padding:6px 12px; background:#1a1a1a; color:#c9a050; border:1px solid #c9a050; border-radius:4px; cursor:pointer; font-size:12px; font-weight:bold; margin:3px;";
    
    const overlay = document.createElement('div');
    overlay.style = 'position:fixed; top:50%; left:50%; transform:translate(-50%, -120%); width:400px; background:#1a1a1a; color:#c9a050; border:2px solid #c9a050; padding:20px; z-index:2147483649; border-radius:10px; display:none; box-shadow: 0 0 20px rgba(0,0,0,0.8); font-family:sans-serif; text-align:center;';
    document.body.appendChild(overlay);
 
    const container = document.createElement('div');
    container.style = 'position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:2147483648; display:none; background:#000; padding:10px; border-radius:8px; border:2px solid #c9a050;';
    document.body.appendChild(container);
    
    const striktBtn = document.createElement('button'); striktBtn.innerText = '&#128142; AI-Strikt'; striktBtn.style = btnStyle;
    const kreativBtn = document.createElement('button'); kreativBtn.innerText = '&#129514; AI-Kreativ'; kreativBtn.style = btnStyle;
    const gBtn = document.createElement('button'); gBtn.innerText = '&#128269; Google'; gBtn.style = btnStyle;
    container.appendChild(striktBtn); container.appendChild(kreativBtn); container.appendChild(gBtn);
 
    function renderOverlay(info) {
        overlay.innerHTML = `<h3 style="color:#fff; margin-top:0;">${info.name || 'Kein Treffer'}</h3><p style="font-size:14px; margin-bottom:20px;">${info.details || ''}</p><div style="display:flex; gap:10px; justify-content:center;"><button id="wb-btn" style="${btnStyle}">&#128269; WB</button><button id="gl-btn" style="${btnStyle}">&#127760; Reviews</button><button id="close-btn" style="${btnStyle} border-color:red; color:red;">&#10006;</button></div>`;
        overlay.style.display = 'block';
        document.getElementById('wb-btn').onclick = () => window.open(`https://www.whiskybase.com/search?q=${encodeURIComponent(info.name)}`, '_blank');
        document.getElementById('gl-btn').onclick = () => window.open(`https://www.google.com/search?q=${encodeURIComponent(info.name + " review")}`, '_blank');
        document.getElementById('close-btn').onclick = () => overlay.style.display = 'none';
    }
 
    async function runAISearch(mode) {
        const sel = window.getSelection().toString().trim();
        const isStrikt = (mode === 'strikt');
        const key = getApiKey();
        if (!key) return;
 
        if (isStrikt) {
            const selLower = sel.toLowerCase();
            const hasMatch = whiskySources.some(s => selLower.includes(s.toLowerCase()));
            if (!hasMatch) { alert("Kein Datenbank-Treffer gefunden."); return; }
        }
 
        const statusEl = isStrikt ? striktBtn : kreativBtn;
        statusEl.innerText = '&#9203; ...';
        container.style.display = 'none';
 
        const promptText = isStrikt ? 
            `Extrahiere aus "${sel}" nur Namen aus dieser Liste: ${whiskySources.join(", ")} plus Jahreszahl. JSON format: {"name": "...", "details": "..."}` :
            `Extrahiere Whisky-Infos aus: "${sel}". JSON format: {"name": "...", "details": "..."}`;
 
        GM_xmlhttpRequest({
            method: "POST",
            url: `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${key}`,
            headers: { "Content-Type": "application/json" },
            data: JSON.stringify({ contents: [{ parts: [{ text: promptText }] }] }),
            onload: (res) => {
                try {
                    const data = JSON.parse(res.responseText);
                    const text = data.candidates[0].content.parts[0].text;
                    let raw = text.replace(/```json/g, "").replace(/```/g, "").trim();
                    renderOverlay(JSON.parse(raw.substring(raw.indexOf('{'), raw.lastIndexOf('}') + 1)));
                } catch(e) { console.error("Parse-Fehler", e); }
                statusEl.innerText = isStrikt ? '&#128142; AI-Strikt' : '&#129514; AI-Kreativ';
            }
        });
    }
 
    striktBtn.addEventListener('click', () => runAISearch('strikt'));
    kreativBtn.addEventListener('click', () => runAISearch('kreativ'));
    gBtn.onclick = () => { window.open(`https://www.google.com/search?q=${encodeURIComponent(window.getSelection().toString().trim() + " Whiskybase")}`, '_blank'); container.style.display = 'none'; };
 
    document.addEventListener('mouseup', (e) => {
        setTimeout(() => {
            let sel = window.getSelection().toString().trim();
            if (sel.length > 3) container.style.display = 'flex';
            else if (!container.contains(e.target)) container.style.display = 'none';
        }, 150);
    }, true);
})();
