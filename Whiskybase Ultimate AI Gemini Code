// ==UserScript==
// @name         Whiskybase Ultimate AI V30.5 (Gemini Cascade)
// @version      30.5
// @description  Strikte Extraktion mit Gemini-Kaskade: 2.0 Flash -> 1.5 Pro -> 1.5 Flash
// @author       Gemini
// @match        *://*/*
// @grant        GM_xmlhttpRequest
// @grant        GM_getValue
// @grant        GM_setValue
// @connect      generativelanguage.googleapis.com
// @connect      gist.githubusercontent.com
// ==/UserScript==

(function() {
    'use strict';
    const DB_URL = 'https://gist.githubusercontent.com/aelfric2/5dd08669d7d4b4a9f3b25d1b98e91120/raw/whiskydb.json';
    let whiskySources = [];
    const models = ["gemini-2.0-flash-exp", "gemini-1.5-pro", "gemini-1.5-flash"];

    function getApiKey() {
        let key = GM_getValue('gemini_key', null);
        if (!key) {
            key = prompt("Whiskybase AI: Bitte gib deinen Google Gemini API-Key ein:");
            if (key) GM_setValue('gemini_key', key);
        }
        return key;
    }

    // Datenbank-Laden (wie bisher)
    GM_xmlhttpRequest({
        method: "GET",
        url: DB_URL + "?t=" + Date.now(),
        onload: (res) => {
            try {
                const data = JSON.parse(res.responseText);
                let allTerms = [];
                Object.keys(data).forEach(key => { if (Array.isArray(data[key])) allTerms = allTerms.concat(data[key]); });
                whiskySources = [...new Set(allTerms)];
            } catch(e) { console.error("DB-Fehler", e); }
        }
    });

    // [Overlay & Container Code von V30.3 hier einfügen]

    async function callGemini(key, modelIndex, promptText, inputData, callback) {
        if (modelIndex >= models.length) { console.error("Alle Gemini-Modelle fehlgeschlagen."); return; }
        
        const model = models[modelIndex];
        const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${key}`;
        
        GM_xmlhttpRequest({
            method: "POST",
            url: url,
            headers: { "Content-Type": "application/json" },
            data: JSON.stringify({ contents: [{ role: "user", parts: [{ text: `System: ${promptText}\nInput: ${inputData}` }] }] }),
            onload: (res) => {
                try {
                    const data = JSON.parse(res.responseText);
                    const raw = data.candidates[0].content.parts[0].text.replace(/```json/g, "").replace(/```/g, "").trim();
                    callback(JSON.parse(raw.substring(raw.indexOf('{'), raw.lastIndexOf('}') + 1)));
                } catch(e) {
                    console.warn(`Modell ${model} fehlgeschlagen, versuche nächstes...`);
                    callGemini(key, modelIndex + 1, promptText, inputData, callback);
                }
            }
        });
    }

    async function runAISearch(mode) {
        const sel = window.getSelection().toString().trim();
        const isStrikt = (mode === 'strikt');
        const key = getApiKey();
        if (!key) return;

        let foundTerms = isStrikt ? whiskySources.filter(s => sel.toLowerCase().includes(s.toLowerCase())) : [];
        if (isStrikt && foundTerms.length === 0) { alert("Kein Datenbank-Treffer."); return; }

        const systemPrompt = isStrikt ?
            `Du bist ein strikter Parser. Whitelist: ${foundTerms.join(", ")}. Schema: [Whitelist] [Erstes Jahr] [Alter]. Regeln: Lösche "Jahre", "yo", "years", "Cask", "Fass", "Finish", "PST", "SMoS". JSON: {"name": "...", "details": "..."}.` :
            "Du bist ein Whisky-Experte. Antworte NUR als valides JSON: {'name': 'Titel + Details', 'details': 'Zusammenfassung'}.";

        callGemini(key, 0, systemPrompt, sel, (info) => renderOverlay(info));
    }

    // [Event-Listener Code von V30.3 hier einfügen]
})();
