// ==UserScript==
// @name         Whiskybase Ultimate AI V30.3 (Final Polish)
// @version      30.3
// @description  Strikte Extraktion: Whitelist-Priorität, nur das erste Jahr eines Zeitraums, Alter als 2-stellige Zahl.
// @author       Gemini
// @match        *://*/*
// @grant        GM_xmlhttpRequest
// @grant        GM_getValue
// @grant        GM_setValue
// @connect      api.openai.com
// @connect      gist.githubusercontent.com
// ==/UserScript==

(function() {
    'use strict';
    const DB_URL = 'https://gist.githubusercontent.com/aelfric2/5dd08669d7d4b4a9f3b25d1b98e91120/raw/whiskydb.json';
    let whiskySources = [];

    function getApiKey() {
        let key = GM_getValue('openai_key', null);
        if (!key) {
            key = prompt("Whiskybase Ultimate AI: Bitte gib deinen OpenAI API-Key ein:");
            if (key) GM_setValue('openai_key', key);
        }
        return key;
    }

    GM_xmlhttpRequest({
        method: "GET",
        url: DB_URL + "?t=" + Date.now(),
        onload: (res) => {
            try {
                const data = JSON.parse(res.responseText);
                let allTerms = [];
                Object.keys(data).forEach(key => {
                    if (Array.isArray(data[key])) {
                        allTerms = allTerms.concat(data[key]);
                    }
                });
                whiskySources = [...new Set(allTerms)];
                console.log("Whiskybase AI: Datenbank geladen, Begriffe gefunden:", whiskySources.length);
            } catch(e) { console.error("Whiskybase AI: JSON-Fehler", e); }
        }
    });

    const btnStyle = "padding:6px 12px; background:#1a1a1a; color:#c9a050; border:1px solid #c9a050; border-radius:4px; cursor:pointer; font-size:12px; font-weight:bold; margin:3px;";
    const overlay = document.createElement('div');
    overlay.style = 'position:fixed; top:50%; left:50%; transform:translate(-50%, -120%); width:400px; background:#1a1a1a; color:#c9a050; border:2px solid #c9a050; padding:20px; z-index:2147483649; border-radius:10px; display:none; box-shadow: 0 0 20px rgba(0,0,0,0.8); font-family:sans-serif; text-align:center;';
    document.body.appendChild(overlay);

    const container = document.createElement('div');
    container.style = 'position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:2147483648; display:none; background:#000; padding:10px; border-radius:8px; border:2px solid #c9a050;';
    document.body.appendChild(container);

    const striktBtn = document.createElement('button'); striktBtn.innerText = '💎 AI-Strikt'; striktBtn.style = btnStyle;
    const kreativBtn = document.createElement('button'); kreativBtn.innerText = '🧪 AI-Kreativ'; kreativBtn.style = btnStyle;
    const gBtn = document.createElement('button'); gBtn.innerText = '🔍 Google'; gBtn.style = btnStyle;
    container.appendChild(striktBtn); container.appendChild(kreativBtn); container.appendChild(gBtn);

    function renderOverlay(info) {
        overlay.innerHTML = `<h3 style="color:#fff; margin-top:0;">${info.name || 'Kein Treffer'}</h3><p style="font-size:14px; margin-bottom:20px;">${info.details || ''}</p><div style="display:flex; gap:10px; justify-content:center;"><button id="wb-btn" style="${btnStyle}">🔍 WB</button><button id="gl-btn" style="${btnStyle}">🌐 Reviews</button><button id="close-btn" style="${btnStyle} border-color:red; color:red;">✖</button></div>`;
        overlay.style.display = 'block';
        document.getElementById('wb-btn').onclick = () => window.open(`https://www.whiskybase.com/search?q=${encodeURIComponent(info.name)}`, '_blank');
        document.getElementById('gl-btn').onclick = () => window.open(`https://www.google.com/search?q=${encodeURIComponent(info.name + " review")}`, '_blank');
        document.getElementById('close-btn').onclick = () => overlay.style.display = 'none';
    }

    async function runAISearch(mode) {
        const sel = window.getSelection().toString().trim();
        const isStrikt = (mode === 'strikt');
        const key = getApiKey();
        if (!key) return;

        let foundTerms = [];
        if (isStrikt) {
            const selLower = sel.toLowerCase();
            foundTerms = whiskySources.filter(s => selLower.includes(s.toLowerCase()));
            if (foundTerms.length === 0) {
                alert("Kein Datenbank-Treffer gefunden.");
                return;
            }
        }

        const statusEl = isStrikt ? striktBtn : kreativBtn;
        statusEl.innerText = '⏳ ...';
        container.style.display = 'none';

        const systemPrompt = isStrikt ?
            `Du bist ein strikter Datenbank-Parser.
            Input: "${sel}"
            Whitelist: "${foundTerms.join(", ")}"
            Aufgabe: Erstelle einen Suchstring nach Schema: [Whitelist-Begriffe] [Erstes Jahr] [Alter].
            REGELN:
            1. Whitelist-Begriffe MÜSSEN übernommen werden.
            2. Jahreszahl: Nimm NUR das erste Jahr eines Zeitraums (z.B. bei "2009/2025" -> "2009").
            3. Alter: Extrahiere die Zahl vor "y.o.", "Jahre" oder "years". Format: 2-stellig (z.B. "15").
            4. VERBOTEN: Alles andere, wie "y.o.", "Jahre", "years", "Cask", "Fass", "Finish", "PST", "SMoS", "Hogshead".
            5. Ausgabe: JSON {"name": "Whitelist-Begriffe Jahr Alter", "details": "Alter-Zahl"}.` :
            "Du bist ein Whisky-Experte. Antworte NUR als valides JSON: {'name': 'Titel + Details', 'details': 'Zusammenfassung'}.";

        GM_xmlhttpRequest({
            method: "POST",
            url: "https://api.openai.com/v1/chat/completions",
            headers: { "Content-Type": "application/json", "Authorization": `Bearer ${key}` },
            data: JSON.stringify({
                model: "gpt-4o-mini",
                messages: [{ role: "system", content: systemPrompt }, { role: "user", content: `Input: "${sel}"` }]
            }),
            onload: (res) => {
                try {
                    const data = JSON.parse(res.responseText);
                    let raw = data.choices[0].message.content.replace(/```json/g, "").replace(/```/g, "").replace(/'/g, '"').trim();
                    renderOverlay(JSON.parse(raw.substring(raw.indexOf('{'), raw.lastIndexOf('}') + 1)));
                } catch(e) { console.error("Parse-Fehler", e); }
                statusEl.innerText = isStrikt ? '💎 AI-Strikt' : '🧪 AI-Kreativ';
            }
        });
    }

    striktBtn.addEventListener('click', () => runAISearch('strikt'));
    kreativBtn.addEventListener('click', () => runAISearch('kreativ'));
    gBtn.onclick = () => { window.open(`https://www.google.com/search?q=${encodeURIComponent(window.getSelection().toString().trim() + " Whiskybase")}`, '_blank'); container.style.display = 'none'; };

    document.addEventListener('mouseup', (e) => {
        setTimeout(() => {
            let sel = window.getSelection().toString().trim();
            if (sel.length > 3) container.style.display = 'flex';
            else if (!container.contains(e.target)) container.style.display = 'none';
        }, 150);
    }, true);
})();
