// ==UserScript==
// @name         Whiskybase Ultimate AI V27.0 (Gemini Free)
// @version      27.0
// @description  Integration von Google Gemini Free Tier mit Fallback-Logik
// @author       Gemini
// @match        *://*/*
// @grant        GM_xmlhttpRequest
// @connect      generativelanguage.googleapis.com
// @connect      gist.githubusercontent.com
// ==/UserScript==

(function() {
    'use strict';
    const GEMINI_KEY = 'DEIN_GOOGLE_AI_STUDIO_KEY_HIER';
    const DB_URL = 'https://gist.githubusercontent.com/aelfric2/5dd08669d7d4b4a9f3b25d1b98e91120/raw/0b6a6c1b14d2004587d4b8a798d2cd4dca09a1a7/whiskydb.json';
    
    let whiskyDB = [];

    // DB Laden
    GM_xmlhttpRequest({
        method: "GET",
        url: DB_URL,
        onload: (res) => { try { const data = JSON.parse(res.responseText); whiskyDB = Array.isArray(data) ? data : (data.whiskies || []); } catch(e) {} }
    });

    const btnStyle = "padding:6px 12px; background:#1a1a1a; color:#c9a050; border:1px solid #c9a050; border-radius:4px; cursor:pointer; font-size:12px; font-weight:bold; margin:3px;";

    const overlay = document.createElement('div');
    overlay.style = 'position:fixed; top:50%; left:50%; transform:translate(-50%, -120%); width:400px; background:#1a1a1a; color:#c9a050; border:2px solid #c9a050; padding:20px; z-index:2147483649; border-radius:10px; display:none; box-shadow: 0 0 20px rgba(0,0,0,0.8); font-family:sans-serif; text-align:center;';
    document.body.appendChild(overlay);

    const container = document.createElement('div');
    container.style = 'position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:2147483648; display:none; background:#000; padding:10px; border-radius:8px; border:2px solid #c9a050;';
    document.body.appendChild(container);
    
    const striktBtn = document.createElement('button'); striktBtn.innerText = '💎 AI-Strikt'; striktBtn.style = btnStyle;
    const kreativBtn = document.createElement('button'); kreativBtn.innerText = '🧪 AI-Kreativ'; kreativBtn.style = btnStyle;
    const gBtn = document.createElement('button'); gBtn.innerText = '🔍 Google'; gBtn.style = btnStyle;
    container.appendChild(striktBtn); container.appendChild(kreativBtn); container.appendChild(gBtn);

    function renderOverlay(info) {
        overlay.innerHTML = `<h3 style="color:#fff; margin-top:0;">${info.name || 'Kein Name'}</h3><p style="font-size:14px; margin-bottom:20px;">${info.details || ''}</p><div style="display:flex; gap:10px; justify-content:center;"><button id="wb-btn" style="${btnStyle}">🔍 WB</button><button id="gl-btn" style="${btnStyle}">🌐 Reviews</button><button id="close-btn" style="${btnStyle} border-color:red; color:red;">✖</button></div>`;
        overlay.style.display = 'block';
        document.getElementById('wb-btn').onclick = () => window.open(`https://www.whiskybase.com/search?q=${encodeURIComponent(info.name)}`, '_blank');
        document.getElementById('gl-btn').onclick = () => window.open(`https://www.google.com/search?q=${encodeURIComponent(info.name + " review")}`, '_blank');
        document.getElementById('close-btn').onclick = () => overlay.style.display = 'none';
    }

    async function callGemini(mode, model, promptText) {
        return new Promise((resolve, reject) => {
            GM_xmlhttpRequest({
                method: "POST",
                url: `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${GEMINI_KEY}`,
                headers: { "Content-Type": "application/json" },
                data: JSON.stringify({ contents: [{ parts: [{ text: promptText }] }] }),
                onload: (res) => {
                    try {
                        const json = JSON.parse(res.responseText);
                        const text = json.candidates[0].content.parts[0].text;
                        resolve(text.replace(/```json/g, "").replace(/```/g, "").replace(/'/g, '"').trim());
                    } catch(e) { reject(e); }
                },
                onerror: reject
            });
        });
    }

    async function runAISearch(mode) {
        const sel = window.getSelection().toString().trim();
        const isStrikt = (mode === 'strikt');
        (isStrikt ? striktBtn : kreativBtn).innerText = '⏳ ...';
        container.style.display = 'none';

        let dbContext = isStrikt ? (whiskyDB.find(i => i.name && sel.toLowerCase().includes(i.name.toLowerCase())) || "Kein Treffer") : "";
        const prompt = isStrikt ? 
            `Extrahiere Infos aus: "${sel}". DB: ${JSON.stringify(dbContext)}. Antworte NUR als JSON: {"name": "Name + Jahr", "details": "Fass"}.` :
            `Analysiere: "${sel}". Antworte NUR als JSON: {"name": "Titel", "details": "Zusammenfassung"}.`;

        // Fallback-Logik: Erst 1.5-Flash, dann 1.5-Pro
        try {
            const raw = await callGemini(mode, "gemini-1.5-flash", prompt);
            renderOverlay(JSON.parse(raw.substring(raw.indexOf('{'), raw.lastIndexOf('}') + 1)));
        } catch(e) {
            console.warn("Flash fehlgeschlagen, versuche Pro...");
            const raw = await callGemini(mode, "gemini-1.5-pro", prompt);
            renderOverlay(JSON.parse(raw.substring(raw.indexOf('{'), raw.lastIndexOf('}') + 1)));
        }
        (isStrikt ? striktBtn : kreativBtn).innerText = isStrikt ? '💎 AI-Strikt' : '🧪 AI-Kreativ';
    }

    striktBtn.addEventListener('click', () => runAISearch('strikt'));
    kreativBtn.addEventListener('click', () => runAISearch('kreativ'));
    gBtn.onclick = () => { window.open(`https://www.google.com/search?q=${encodeURIComponent(window.getSelection().toString().trim() + " Whiskybase")}`, '_blank'); container.style.display = 'none'; };

    document.addEventListener('mouseup', (e) => {
        setTimeout(() => {
            if (window.getSelection().toString().trim().length > 3) container.style.display = 'flex';
            else if (!container.contains(e.target)) container.style.display = 'none';
        }, 150);
    }, true);
})();
